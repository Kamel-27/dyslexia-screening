# ──────────────────────────────────────────────────────────────
# DysTest Gamified ML Service — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8001

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the web frontend.
# Default allows the local Next.js dev server.
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Debug ─────────────────────────────────────────────────────
# Set to true for verbose logging (do NOT use in production).
DEBUG=false
